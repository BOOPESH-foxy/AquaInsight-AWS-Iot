REGION=your-preferred-region
ACCOUNT_ID=your-aws-acc-id

# vpc config
VPC_NAME=AquaInsight-VPC
CIDR_BLOCK=10.0.0.0/16
SECURITY_GROUP_NAME=AquaInsight-SG
SUBNET_CIDR_BLOCKS=10.0.1.0/24,10.0.2.0/24

# ecs config
ECS_CLUSTER_NAME=AquaInsight-Cluster
ECS_SERVICE_NAME=AquaInsight-Service
ECS_TASK_FAMILY=AquaInsight-Task
ECR_REPOSITORY=aqua-container
LOG_GROUP=/aws/ecs/aquainsight

# IoT Configuration
ENDPOINT=your-iot-endpoint.iot.region.amazonaws.com

# InfluxDB Configuration (Amazon Timestream for InfluxDB)
INFLUX_DB_INSTANCE_NAME=aquainsight-influxdb
INFLUX_DB_INSTANCE_TYPE=db.influx.large
INFLUX_STORAGE_TYPE=InfluxIOIncludedT1
INFLUX_ALLOCATED_STORAGE=20
INFLUX_USERNAME=aquainsight-admin
INFLUX_PASSWORD=your-secure-password
INFLUX_ORGANIZATION=AquaInsight
INFLUX_BUCKET=water-quality-data

# SNS Configuration
SNS_TOPIC_NAME=AquaInsight-Alerts
SNS_DISPLAY_NAME=AquaInsight Water Quality Alerts
ALERT_EMAIL_SUBSCRIBERS=your-email@example.com,admin@example.com

# Water Quality Alert Thresholds
ALERT_TDS_MAX=500
ALERT_TURBIDITY_MAX=4.0
ALERT_CHLORINE_MIN=0.2
ALERT_CHLORINE_MAX=4.0
ALERT_PH_MIN=6.5
ALERT_PH_MAX=8.5